---
import { CldImage } from "astro-cloudinary";

interface Props {
  src: string;
  alt?: string;
}

const { src, alt = "", ...rest } = Astro.props;
---

<style>
  :global(.astro-cloudinary-cldimage) {
    width: 100%;
    height: auto;
    border: 0.5px solid var(--semantic-border-low);
    border-radius: var(--radii-medium);
  }
</style>

<!-- SRC relativo a la carpeta de imágenes (/images) -->
<CldImage src={src} alt={alt} width={1200} {...rest} loading={"lazy"} />
