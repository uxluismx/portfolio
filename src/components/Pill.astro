---
import IconWrapper from "./IconWrapper.astro";

interface PillProps {
  text: string;
  nameIcon?: string;
}

const { text, nameIcon } = Astro.props;
---

<style>
  .pill {
    width: fit-content;
    align-items: center;
    justify-content: center;
    padding: 0.21875rem 0.625rem;
    background-color: var(--semantic-on-surface-low);
    border-radius: var(--radii-xsmall);
    color: var(--semantic-secondary);
    gap: 0.375rem;

    p {
      color: inherit;
    }
  }
</style>

<div class="pill flex-row stroke-small">
  {nameIcon && <IconWrapper name={nameIcon} size="16" />}
  <p class="body-small">{text}</p>
</div>
