---
import Pill from "./Pill.astro";

interface Props {
  title: string;
  description: string;
  imageName: string;
  imageAlt: string;
  href: string;
  pill?: string[];
  newTab?: boolean;
}

const { title, description, imageName, imageAlt, href, pill, newTab } = Astro.props;
---

<style>
  .project-card {
    gap: 1rem;
    transition: all 200ms ease;

    &:hover {
      .mockup-area {
        transform: translateY(4px);
      }

      .project-card-footer h2 {
        text-decoration: underline;
      }
    }
  }

  .mockup-area {
    width: 100%;
    aspect-ratio: 16/11.5;
    background-color: var(--semantic-on-surface-low);
    border-radius: var(--radii-medium);
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    transition: inherit;

    img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
      aspect-ratio: 16/11.38;
      border-radius: 0.375rem;
    }
  }

  .project-card-footer {
    gap: 0.5rem;

    .title {
      color: var(--semantic-primary);
    }

    .description {
      color: var(--semantic-tertiary);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  .group-pill {
    margin-top: 0.25rem;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>

<a class="flex-column project-card" href={href} target={newTab !== false ? "_blank" : "_self"}>
  <div class="mockup-area stroke-xsmall">
    <img class="stroke-xsmall" src={`/images/${imageName}.webp`} alt={imageAlt} />
  </div>
  <div class="flex-column project-card-footer">
    <h2 class="title display-smallest">{title}</h2>
    <p class="description body-normal">{description}</p>
    {
      pill && (
        <div class="group-pill flex-row">
          {pill.map((text) => (
            <Pill text={text} />
          ))}
        </div>
      )
    }
  </div>
</a>
