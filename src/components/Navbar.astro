---
import Button from "./Button.astro";

interface Props {
  isActive: "Inicio" | "Proyectos" | "Contacto" | string;
}

const { isActive } = Astro.props;
---

<style>
  .navbar {
    width: fit-content;
    background: var(--bw-white);
    padding: 0.5rem;
    gap: 0.5rem;
    border-radius: var(--radii-full);
  }

  .navbar-container {
    gap: inherit;
  }

  & :global(.button) {
    min-width: 6rem;
  }
</style>

<nav class="flex-row navbar stroke-xsmall shadow-small">
  <Button
    href="/"
    type={isActive === "Inicio" ? "CTA" : "Link"}
    size="SM"
    text="Inicio"
    animation={false}
  />
  <Button
    href="/proyectos"
    type={isActive === "Proyectos" ? "CTA" : "Link"}
    size="SM"
    text="Proyectos"
    animation={false}
  />
  <Button
    href="mailto:uxluismx@gmail.com"
    type={isActive === "Contacto" ? "CTA" : "Link"}
    size="SM"
    text="Contacto"
    animation={false}
  />
  <slot />
</nav>
